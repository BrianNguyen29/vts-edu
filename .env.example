# Root .env.example
# Copy to .env and fill in real values. Never commit .env files.
# See config/README.md for environment-specific guidance.

# Shared
ENVIRONMENT=development

# Frontend (Vercel) - see config/vercel.env.example
# VITE_API_BASE_URL=http://localhost:8080/api/v1

# Backend (Render) - see config/render.env.example
# PORT=8080
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/vtsedu?sslmode=disable
# FRONTEND_ORIGINS=http://localhost:5173
# JWT_SIGNING_KEY=replace-with-random-256-bit-key
# REFRESH_TOKEN_KEY=replace-with-random-256-bit-key

# Supabase - see config/supabase.env.example
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
# SUPABASE_STORAGE_BUCKET=vts-edu-files
