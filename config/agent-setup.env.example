# Agent Setup Checklist
# Copy this file and fill in real values. Never commit secrets.
# This file consolidates every key needed across Vercel, Supabase, Render, frontend,
# backend, and agent CLI access. Checked boxes mean the value has been supplied.

# -----------------------------------------------------------------------------
# 1. Vercel / Frontend
# Apply at: Vercel dashboard → Project Settings → Environment Variables
# -----------------------------------------------------------------------------

# [ ] VITE_API_BASE_URL — Absolute Render API origin used by the SPA at runtime.
# Example: https://<your-render-service>.onrender.com/api/v1
VITE_API_BASE_URL=https://<your-render-service>.onrender.com/api/v1

# [ ] VITE_APP_NAME — Optional build-time app name.
VITE_APP_NAME=VTS EDU

# -----------------------------------------------------------------------------
# 2. Supabase
# Apply at: Supabase dashboard → Project Settings → API / Database
# -----------------------------------------------------------------------------

# [ ] SUPABASE_PROJECT_ID — Project reference ID (used by Supabase CLI).
SUPABASE_PROJECT_ID=<your-project-ref>

# [ ] SUPABASE_URL — Project URL.
SUPABASE_URL=https://<your-project>.supabase.co

# [ ] SUPABASE_SERVICE_ROLE_KEY — Service role key (backend only; never expose to frontend).
SUPABASE_SERVICE_ROLE_KEY=<replace-with-service-role-key>

# [ ] SUPABASE_ANON_KEY — Public anon key (used by frontend if needed).
SUPABASE_ANON_KEY=<replace-with-anon-key>

# [ ] SUPABASE_STORAGE_BUCKET — Storage bucket name.
SUPABASE_STORAGE_BUCKET=vts-edu-files

# -----------------------------------------------------------------------------
# 3. Backend / Render
# Apply at: Render dashboard → Web Service → Environment Variables
# -----------------------------------------------------------------------------

# [ ] PORT — HTTP port the Go service listens on.
PORT=8080

# [ ] ENVIRONMENT — Runtime environment.
ENVIRONMENT=production

# [ ] FRONTEND_ORIGINS — Comma-separated allowed frontend origins. No wildcard with credentials.
FRONTEND_ORIGINS=https://<your-vercel-app>.vercel.app,https://<your-vercel-app>-<git-sha>.vercel.app

# [ ] DATABASE_URL — Postgres connection string (Supabase transaction pooler or direct connection).
# Transaction pooler (Supavisor):
#   postgres://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
# Direct connection:
#   postgres://postgres.<project>:<password>@db.<project>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgres://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require

# [ ] DB_MAX_OPEN_CONNS — Max open DB connections.
DB_MAX_OPEN_CONNS=5

# [ ] DB_MAX_IDLE_CONNS — Max idle DB connections.
DB_MAX_IDLE_CONNS=2

# [ ] JWT_SIGNING_KEY — 256-bit random key (hex or base64).
JWT_SIGNING_KEY=REPLACE_WITH_RANDOM_256_BIT_KEY

# [ ] REFRESH_TOKEN_KEY — 256-bit random key (hex or base64).
REFRESH_TOKEN_KEY=REPLACE_WITH_RANDOM_256_BIT_KEY

# [ ] ACCESS_TOKEN_TTL — Access token lifetime.
ACCESS_TOKEN_TTL=15m

# [ ] REFRESH_TOKEN_TTL — Refresh token lifetime.
REFRESH_TOKEN_TTL=7d

# -----------------------------------------------------------------------------
# 4. Agent CLI Access
# Apply at: agent environment or local shell. Do not commit tokens to the repo.
# These tokens let the agent run Vercel, Supabase, and Render CLI commands.
# -----------------------------------------------------------------------------

# [ ] VERCEL_TOKEN — Vercel CLI personal token (from https://vercel.com/account/tokens).
VERCEL_TOKEN=<replace-with-vercel-token>

# [ ] SUPABASE_ACCESS_TOKEN — Supabase CLI personal access token (from Supabase dashboard).
SUPABASE_ACCESS_TOKEN=<replace-with-supabase-access-token>

# [ ] RENDER_API_KEY — Render CLI/API key (from Render dashboard → Account Settings).
RENDER_API_KEY=<replace-with-render-api-key>

# -----------------------------------------------------------------------------
# 5. GitHub Actions
# Apply at: GitHub repository → Settings → Secrets and variables → Actions
# -----------------------------------------------------------------------------

# [ ] SUPABASE_DB_URL — Postgres connection string used by the pg_dump backup workflow.
SUPABASE_DB_URL=postgres://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
