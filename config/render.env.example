# Render / Backend environment variables
# Set these as environment variables on the Render Web Service.
# The current demo stack uses Render Free for the Go API.

# Server
PORT=8080
ENVIRONMENT=production

# CORS: comma-separated list of allowed frontend origins. No wildcard with credentials.
FRONTEND_ORIGINS=https://<your-vercel-app>.vercel.app,https://<your-vercel-app>-<git-sha>.vercel.app

# Database
# Supabase connection string (transaction pooler / direct are both valid depending on plan).
DATABASE_URL=postgres://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DB_MAX_OPEN_CONNS=5
DB_MAX_IDLE_CONNS=2

# Auth (256-bit random keys, hex or base64)
JWT_SIGNING_KEY=REPLACE_WITH_RANDOM_256_BIT_KEY
REFRESH_TOKEN_KEY=REPLACE_WITH_RANDOM_256_BIT_KEY
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Supabase Storage
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<replace-with-service-role-key>
SUPABASE_STORAGE_BUCKET=vts-edu-files
